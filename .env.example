# Whiskey Vault — build-time configuration (Expo public env vars).
# Copy to `.env` and fill in, or set these in your EAS build profile's `env`.
# All are optional; unset means the app runs fully local (no backend calls).

# Base URL of the analytics-service (server/analytics-service). When set AND the
# user has opted in to analytics, the app flushes its anonymized event queue to
# <URL>/v1/events on launch. Must be https in production.
EXPO_PUBLIC_ANALYTICS_URL=

# EAS project id, used to mint Expo push tokens for remote notifications.
# `eas init` writes this into app.json (extra.eas.projectId) automatically; set
# it here only to override. Auto-detected in EAS builds.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Base URL of the push-service (server/push-service). When set, the app registers
# its Expo push token there so you can send remote alerts. https in production.
EXPO_PUBLIC_PUSH_URL=

# Pricing backend base URL (server/affiliate-price-service). Configured in
# src/config.ts (PRICING_API_BASE_URL) today; documented here for completeness.
# EXPO_PUBLIC_PRICING_URL=
