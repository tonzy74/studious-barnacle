# Copy to .env and fill in once you're approved for affiliate programs.
PORT=8787

# Feed source: "sample" (default, demo data) or "impact"
FEED_SOURCE=sample

# Your affiliate tracking (so tap-and-buy earns you commission)
IMPACT_PUBLISHER_ID=
AFFILIATE_SUBID=whiskeyvault-app

# Impact Catalog API credentials (when FEED_SOURCE=impact)
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=
IMPACT_CATALOG_IDS=
